# ── Sentinel Hub OAuth2 client credentials ───────────────────────────────────
# These are NOT the "API Key" on your profile page. They are a separate OAuth2
# client that you create:
#
#   Planet Insights Platform → top-left menu → Account → Users
#   → click your username → "OAuth clients" tab → "+ Add client"
#   → copy the client_id shown, then reveal and copy the client_secret
#
# Free Trial allows creating OAuth clients. Each client gets its own pair.

SH_CLIENT_ID=your-oauth-client-id-here
SH_CLIENT_SECRET=your-oauth-client-secret-here

# ── LRIS Portal API key ───────────────────────────────────────────────────────
# Register free at https://lris.scinfo.org.nz → sign in → top-right avatar → API keys → + New key
LRIS_API_KEY=your-lris-api-key-here
